{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": false,
    // Re-enable emit (the base config sets noEmit for type-checking only).
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src"],
  "exclude": ["tests"]
}
