{
  "compilerOptions": {
    // Only include Node.js libraries
    "lib": ["ESNext"],

    // Target a more broadly compatible version
    "target": "ES2022",

    "module": "nodenext",

    // Node.js module resolution
    "moduleResolution": "nodenext",

    // Keep strict type checking
    "strict": true,

    // Speed up compilation
    "skipLibCheck": true,

    "rootDir": "."
  },
  "include": ["src", "tests"]
}
