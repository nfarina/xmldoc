{
  "compilerOptions": {
    // Only include Node.js libraries
    "lib": ["ESNext"],

    // Target a more broadly compatible version
    "target": "ES2022",

    "module": "nodenext",

    // Node.js module resolution
    "moduleResolution": "nodenext",

    // Keep strict type checking
    "strict": true,

    // Speed up compilation
    "skipLibCheck": true,

    // This config is for type-checking and editor support only - it must never
    // emit, or a plain `tsc` would scatter .js files across src/ and tests/.
    // The build opts back in via tsconfig.build.json.
    "noEmit": true,

    "rootDir": "."
  },
  "include": ["src", "tests"]
}
